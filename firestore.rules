rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return getUserData().role == 'teacher';
    }

    function isEnrolled(classId) {
      return classId in getUserData().enrolledClasses;
    }

    function isClassTeacher(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // ─── Users collection ────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read their own profile
      allow read: if isAuthenticated() && isOwner(userId);
      // Allow read for teachers (to see students)
      allow read: if isAuthenticated() && isTeacher();
      // Only the user can create/update their own document
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    // ─── Classes collection ──────────────────────────────────────────────
    match /classes/{classId} {
      // Any authenticated user can read class metadata
      allow read: if isAuthenticated();
      // Only teachers can create classes
      allow create: if isAuthenticated() && isTeacher();
      // Only the assigned teacher can update (e.g., toggle isLive)
      allow update: if isAuthenticated() && isClassTeacher(classId);
      allow delete: if false;

      // ── Messages subcollection ──────────────────────────────────────
      match /messages/{messageId} {
        // Only enrolled students or the class teacher can read messages
        allow read: if isAuthenticated() &&
                       (isClassTeacher(classId) || isEnrolled(classId));

        // Enrolled students and teacher can send messages
        allow create: if isAuthenticated() &&
                         (isClassTeacher(classId) || isEnrolled(classId)) &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.isPinned == false;

        // Only the class teacher can pin or delete messages
        allow update: if isAuthenticated() && isClassTeacher(classId) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned']);
        allow delete: if isAuthenticated() && isClassTeacher(classId);
      }

      // ── Attendance subcollection ────────────────────────────────────
      match /attendance/{userId} {
        // Teacher can read all attendance records
        allow read: if isAuthenticated() && isClassTeacher(classId);
        // Student can read only their own
        allow read: if isAuthenticated() && isOwner(userId);
        // Only the user can write their own attendance
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // ── RaisedHands subcollection ────────────────────────────────────
      match /raisedHands/{userId} {
        // Teacher can read all raised hands
        allow read: if isAuthenticated() && isClassTeacher(classId);
        // Students can read their own
        allow read: if isAuthenticated() && isOwner(userId);
        // Enrolled student can raise/lower their own hand
        allow create, update: if isAuthenticated() && isOwner(userId) && isEnrolled(classId);
        // Student can delete their own (lower hand), teacher can delete any (dismiss)
        allow delete: if isAuthenticated() &&
                         (isOwner(userId) || isClassTeacher(classId));
      }
    }
  }
}
